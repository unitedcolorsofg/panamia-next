# ===================================
# Environment Configuration
# ===================================

# Set to false to use real MongoDB, true for in-memory testing
USE_MEMORY_SERVER=false

# Host URL (HTTPS recommended - required for WebRTC features)
NEXT_PUBLIC_HOST_URL="https://localhost:3000"

# Development email receiver
DEV_RECEIVER_EMAIL="your-dev-email@example.com"

# ===================================
# Database Configuration
# ===================================

# IMPORTANT: MongoDB Atlas is REQUIRED for search functionality
# Directory and admin search features use Atlas Search indexes ($search aggregation)
# which are not available in local MongoDB instances

# MongoDB Atlas (required for search)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/panamia

# Local MongoDB (limited functionality - no search)
# MONGODB_URI=mongodb://localhost:27017/panamia_dev

# ===================================
# NextAuth Configuration
# ===================================

# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-character-secret-here"
NEXTAUTH_URL="https://localhost:3000"

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OATH_SECRET=""

# ===================================
# Cloudflare R2 Object Storage
# ===================================
# Create an R2 API token at: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Enable public access on the bucket to get R2_PUBLIC_URL.
# In wrangler dev / production, the R2_BUCKET binding is used for server-side uploads;
# credentials below are needed for presigned URLs and local Node.js dev.

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="panamia-media"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ===================================
# Pusher Configuration (required for WebRTC mentoring)
# ===================================

PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ===================================
# Stripe Configuration (optional for payments)
# ===================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""

# ===================================
# Brevo Email Service (transactional email)
# ===================================

BREVO_APIKEY=""
BREVO_SENDEREMAIL=""
BREVO_SENDERNAME="PanaMia Club [Dev]"
BREVO_ENV="DEV"

# ===================================
# JWT Secrets (legacy)
# ===================================

NEXT_PUBLIC_JWT_SECRET=""
NEXT_PUBLIC_SECRET=""
