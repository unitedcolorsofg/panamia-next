            "note": "Remote servers may ignore a Delete activity",
            "display": {
              "icon": "share-2",
              "source": "You publish",
              "purpose": "Social federation",
              "retention": "Not recallable",
              "sharedWith": "ActivityPub peers (open set)",
              "prose": "Social posts, replies, likes, and follows federated via ActivityPub — a best-effort Delete is sent, but remote servers may ignore it"
            }
          },
          {
            "name": "nostr_published_events",
