  "peerNetworkingData": {
    "description": "Exchanged directly between participants, or propagated to servers we do not operate; not controlled by Pana MIA Club after transmission",
    "peerNetworkingRetentionClasses": {
      "in_the_wind": {
        "description": "Published to an open, unbounded set of servers we do not operate. Deletion requests are advisory only -- a remote server MAY honor them and MAY ignore them. Neither Pana MIA Club nor anyone else can guarantee retraction once content has propagated.",
        "recallable": false,
        "deletionMechanism": "advisory_request_only",
        "note": "Categorically weaker than third_party_synced. There, a named provider receives a deletion request under a contract. Here there is no enumerable counterparty to ask.",
