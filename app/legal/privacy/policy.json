            "retention": "not_recallable",
            "deletionMechanism": "nip09_delete_request_advisory",
            "note": "A Nostr event is signed by your key and stays cryptographically valid forever, so any relay may rehost it. NIP-09 delete requests are advisory: relays MAY honor them. There is no enumerable list of relays to ask. We can delete from our own relay; no one can delete from Nostr at large.",
            "display": {
              "icon": "radio",
              "source": "You publish",
              "purpose": "Community relay and Nostr interoperability",
              "retention": "Not recallable",
              "sharedWith": "Nostr relays (open set)",
              "prose": "Anything you publish to Nostr — group chat, profile metadata, RSVPs. We can remove it from our own relay; no one can remove it from Nostr at large."
            }
          }
        ]
