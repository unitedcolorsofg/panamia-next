# panamia-crm-bridge — environment variables
# Copy to .dev.vars for local wrangler dev (CF Workers uses .dev.vars, not .env)

# GHL private integration API key
# GHL → Settings → Integrations → Private Integrations
GHL_API_KEY="your_ghl_api_key"

# GHL sub-account/location ID (shown in GHL dashboard URL and Settings)
GHL_LOCATION_ID="your_ghl_location_id"

# HMAC secret used to verify inbound GHL webhook request signatures
# Configure the matching value in GHL → Settings → Webhooks
GHL_WEBHOOK_SECRET="your_ghl_webhook_secret"

# Supabase direct connection string (local dev only — Hyperdrive binding used in production)
POSTGRES_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"
