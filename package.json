{
  "name": "panamia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "env -u NODE_ENV node server.js",
    "build": "vinext build",
    "start": "vinext start",
    "lint": "eslint .",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:relay": "node --import tsx --test tests-relay/*.test.ts",
    "prepare": "husky && (git remote get-url activities-upstream 2>/dev/null || git remote add activities-upstream https://github.com/llun/activities.next.git)",
    "subtree:pull": "git subtree pull --prefix=external/activities.next activities-upstream main --squash",
    "env:check": "npx tsx scripts/env-check.ts check",
    "env:wrangler": "npx tsx scripts/env-check.ts wrangler",
    "env:workflow": "npx tsx scripts/env-check.ts workflow",
    "env:list": "npx tsx scripts/env-check.ts list",
    "env:secrets": "npx tsx scripts/env-check.ts secrets",
    "env:vars": "npx tsx scripts/env-check.ts vars",
    "check:privacy-schema": "npx tsx scripts/check-data-inventory.ts",
    "db:reset": "npx tsx scripts/reset-test-db.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "echo 'This project hand-writes migrations under drizzle/. The drizzle-kit snapshot is intentionally stale (see drizzle.config.ts). If you really need to run drizzle-kit generate, invoke it directly with: npx drizzle-kit generate' && exit 1",
    "db:migrate": "drizzle-kit migrate",
    "dev:setup": "npx tsx scripts/setup-dev-vars.ts",
    "dev:vinext": "vinext dev --port 3001",
    "dev:http": "vinext dev --hostname 0.0.0.0",
    "build:vinext": "vinext build",
    "deploy:vinext": "drizzle-kit migrate && vinext deploy"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@hookform/resolvers": "^5.4.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-accordion": "1.2.17",
    "@radix-ui/react-alert-dialog": "1.1.20",
    "@radix-ui/react-avatar": "1.2.3",
    "@radix-ui/react-checkbox": "1.3.8",
    "@radix-ui/react-dialog": "1.1.20",
    "@radix-ui/react-dropdown-menu": "2.1.21",
    "@radix-ui/react-label": "2.1.12",
    "@radix-ui/react-progress": "1.1.13",
    "@radix-ui/react-radio-group": "1.4.4",
    "@radix-ui/react-scroll-area": "1.2.15",
    "@radix-ui/react-select": "2.3.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "1.1.18",
    "@radix-ui/react-toast": "1.2.20",
    "@tabler/icons-react": "3.45.0",
    "@tailwindcss/postcss": "4.3.3",
    "@tanstack/react-query": "5.101.3",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "aws4fetch": "^1.0.20",
    "axios": "^1.18.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fabric": "^7.4.0",
    "feed": "^5.2.1",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "1.25.0",
    "marked": "18.0.7",
    "nanoid": "^6.0.0",
    "next-themes": "^0.4.6",
    "peggy": "^5.1.0",
    "pigeon-maps": "^0.22.1",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "7.82.0",
    "react-i18next": "17.0.10",
    "react-is": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-qr-code": "^2.2.0",
    "recharts": "3.10.0",
    "stripe": "22.3.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.3",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
