    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "0.5.28",
    "dotenv": "^17.4.2",
    "eslint": "10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "17.1.0",
    "prettier": "3.9.6",
    "prettier-plugin-tailwindcss": "0.8.1",
    "react-server-dom-webpack": "^19.2.7",
    "typescript": "^6.0.3",
    "vinext": "0.2.1",
    "vite": "8.1.5",
    "wrangler": "4.112.0",
    "ws": "8.21.1"
  },
  "resolutions": {
    "undici": "8.0.3",
    "kysely": "0.28.17"
  }
}
