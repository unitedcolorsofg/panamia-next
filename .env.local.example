# =============================================================================
# Environment Variables Configuration
# =============================================================================
#
# Copy this file to .env.local and fill in the values.
#
# Conventions:
#   - Required vars are uncommented. The app will not start without them.
#   - Optional vars are commented out. Uncomment and fill in to enable.
#   - All values are double-quoted (handles spaces and special characters).
#
# GitHub annotations:
#   [SECRET]     - Store in GitHub Secrets (sensitive, encrypted)
#                  Settings → Secrets and variables → Actions → Repository secrets
#                  AND Settings → Secrets and variables → Dependabot → Repository secrets
#   [VAR]        - Store in GitHub Variables (non-sensitive, visible in logs)
#                  Settings → Secrets and variables → Actions → Repository variables
#                  (Dependabot inherits Repository variables automatically — no duplication needed)
#   [LOCAL]      - Only needed for local development, not in CI or CF
#
# Cloudflare annotations:
#   [CF-BUILD]   - CF dashboard -> Workers & Pages -> <app> -> Settings ->
#                  Build -> Variables and secrets
#                  Required during `yarn build` (drizzle-kit migrate + Vite bundle)
#                  NEXT_PUBLIC_* vars must be here — Vite bakes them in at build time
#   [CF-RUNTIME] - Available to the deployed Worker at request time via process.env.
#                  Route by sensitivity:
#                    - Sensitive → `wrangler secret put <NAME>` (or CF dashboard
#                      Variables and secrets → Secret). Persists across deploys.
#                    - Non-sensitive → "vars" block in wrangler.jsonc. Committed
#                      to git, survives deploys.
#                  Do NOT use CF dashboard plaintext (non-secret) vars for runtime —
#                  they get wiped on each CF Workers Builds deploy.
#
# See lib/env.config.ts for the canonical source of truth.
# Run `npm run env:check` to validate your configuration.
#
# IMPORTANT: when you add, rename, or remove any [CF-RUNTIME] var, you must also
# review and update the `vars` block in wrangler.jsonc.
#
# Values do NOT need to match between .env.local and wrangler.jsonc — they are
# different environments. .env.local holds local-dev values; wrangler.jsonc holds
# the production CF Workers values. Most [CF-RUNTIME] vars *should* differ
# (e.g. BETTER_AUTH_URL, BREVO_ENV). `npm run env:check` only compares the
# set of keys, never their values.
#
# =============================================================================

# =============================================================================
# DATABASE (Supabase + Drizzle)
# https://supabase.com/docs/guides/database/connecting-to-postgres
# =============================================================================
#
# Supabase provides three connection string types — use the right one:
#
#   DIRECT (unpooled, port 5432):
#     postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres
#
#   SESSION POOLER (port 5432 via pooler):
#     postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
#
#   TRANSACTION POOLER (port 6543) — DO NOT USE:
#     Transaction mode breaks prepared statements used by postgres.js.
#
# In Cloudflare Workers production, POSTGRES_URL is automatically overridden
# by the HYPERDRIVE binding — it is only used for local dev and CI.
# The Hyperdrive binding ID is NOT an env var; configure it in wrangler.jsonc:
#   "hyperdrive": [{ "binding": "HYPERDRIVE", "id": "<your-hyperdrive-id>" }]
#
# Setup: Supabase dashboard -> Project Settings -> Database -> Connection string

# [SECRET] [CF-BUILD] [CF-RUNTIME] App runtime connection — use the DIRECT or SESSION POOLER string.
POSTGRES_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# [SECRET] [CF-BUILD] Migration-only connection — always use the DIRECT (unpooled) string.
# Required by `npx drizzle-kit migrate` which runs during build and in CI. Never used by the app itself.
# drizzle.config.ts falls back to POSTGRES_URL if this is unset.
# TIP: point the GitHub Secret value at a test Supabase project so CI migrations don't run against production.
POSTGRES_DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# =============================================================================
# AUTHENTICATION (better-auth)
# =============================================================================

# [SECRET] [CF-RUNTIME] better-auth encryption secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your_better_auth_secret_here"

# [VAR] [CF-RUNTIME] Base URL for better-auth callbacks.
# NOTE: Vite bakes process.env.BETTER_AUTH_URL as undefined (CF-RUNTIME vars are
# not present during build). auth.ts falls back to NEXT_PUBLIC_HOST_URL instead.
# Keep this set in CF-RUNTIME for any future direct reads; for origin checking
# NEXT_PUBLIC_HOST_URL is the effective value.
BETTER_AUTH_URL="http://localhost:3000"

# =============================================================================
# HOST CONFIGURATION
# =============================================================================

# [VAR] [CF-BUILD] Public-facing site URL — baked into the Vite bundle at build time
NEXT_PUBLIC_HOST_URL="http://localhost:3000"

# =============================================================================
# ADMIN
# =============================================================================

# [SECRET] [CF-RUNTIME] Comma-separated list of admin email addresses
ADMIN_EMAILS="admin1@example.com,admin2@example.com"

# =============================================================================
# OAUTH PROVIDERS - Google
# https://console.cloud.google.com/apis/credentials
# =============================================================================

# [VAR] [CF-RUNTIME] Google OAuth client ID
# GOOGLE_CLIENT_ID="your_google_client_id_here"

# [SECRET] [CF-RUNTIME] Google OAuth client secret
# GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# =============================================================================
# OAUTH PROVIDERS - Apple
# https://developer.apple.com/account/resources/identifiers/list/serviceId
# =============================================================================

# [VAR] [CF-RUNTIME] Apple OAuth client ID (Services ID)
# APPLE_CLIENT_ID="your_apple_client_id_here"

# [SECRET] [CF-RUNTIME] Apple OAuth client secret (signed JWT)
# APPLE_CLIENT_SECRET="your_apple_client_secret_here"

# =============================================================================
# OAUTH PROVIDERS - Wikimedia
# https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration
# =============================================================================

# [VAR] [CF-RUNTIME] Wikimedia OAuth client ID
# WIKIMEDIA_CLIENT_ID="your_wikimedia_client_id_here"

# [SECRET] [CF-RUNTIME] Wikimedia OAuth client secret
# WIKIMEDIA_CLIENT_SECRET="your_wikimedia_client_secret_here"

# =============================================================================
# OAUTH PROVIDERS - Mastodon
# Create an application on your Mastodon instance
# =============================================================================

# [VAR] [CF-RUNTIME] Mastodon instance URL for OAuth (default: https://mastodon.social)
# MASTODON_INSTANCE="https://mastodon.social"

# [VAR] [CF-RUNTIME] Mastodon OAuth client ID
# MASTODON_CLIENT_ID="your_mastodon_client_id_here"

# [SECRET] [CF-RUNTIME] Mastodon OAuth client secret
# MASTODON_CLIENT_SECRET="your_mastodon_client_secret_here"

# =============================================================================
# OAUTH PROVIDERS - UI Visibility
# Uncomment and set to "true" to show the sign-in button for each provider.
# Also requires the credentials above to be set.
# =============================================================================
#
# These are NEXT_PUBLIC_* — baked into the Vite bundle at build time.
# Set in CF Build variables, not CF Runtime.

# [VAR] [CF-BUILD] Show Google sign-in button (default: false)
# NEXT_PUBLIC_GOOGLE_ENABLED="true"

# [VAR] [CF-BUILD] Show Apple sign-in button (default: false)
# NEXT_PUBLIC_APPLE_ENABLED="true"

# [VAR] [CF-BUILD] Show Wikimedia sign-in button (default: false)
# NEXT_PUBLIC_WIKIMEDIA_ENABLED="true"

# [VAR] [CF-BUILD] Show Mastodon sign-in button (default: false)
# NEXT_PUBLIC_MASTODON_ENABLED="true"

# =============================================================================
# OAUTH PROVIDERS - Trust Level
# Values: "trusted" | "verification-required" | "disabled"
#
# - trusted: Provider verifies email ownership (auto-claim enabled)
# - verification-required: User must verify email before sign-in completes
# - disabled: Provider button greyed out on sign-in page
#
# Defaults apply if unset: Google=trusted, Apple=trusted,
# Wikimedia=verification-required, Mastodon=trusted
# =============================================================================

# [VAR] [CF-RUNTIME] Google OAuth trust level
# OAUTH_GOOGLE="trusted"

# [VAR] [CF-RUNTIME] Apple OAuth trust level
# OAUTH_APPLE="trusted"

# [VAR] [CF-RUNTIME] Wikimedia OAuth trust level
# OAUTH_WIKIMEDIA="verification-required"

# [VAR] [CF-RUNTIME] Mastodon.social OAuth trust level
# OAUTH_MASTODON_SOCIAL="trusted"

# =============================================================================
# RECAPTCHA
# https://www.google.com/recaptcha/admin
# =============================================================================

# [VAR] [CF-BUILD] Google reCAPTCHA v3 site key (public, baked into bundle at build time)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your_recaptcha_site_key_here"

# [SECRET] [CF-RUNTIME] Google reCAPTCHA v3 secret key
RECAPTCHA_SECRET_KEY="your_recaptcha_secret_key_here"

# =============================================================================
# BREVO (Email Service)
# https://app.brevo.com/settings/keys/api
# =============================================================================

# [SECRET] [CF-RUNTIME] Brevo (Sendinblue) API key
# BREVO_APIKEY="your_brevo_api_key"

# [VAR] [CF-BUILD] Brevo sender email address (From: header)
# NEXT_PUBLIC_ prefix ensures Vite bakes this at build time. Non-secret — visible in every email.
# NEXT_PUBLIC_BREVO_SENDEREMAIL="noreply@example.com"

# [VAR] [CF-BUILD] Brevo sender display name
# NEXT_PUBLIC_BREVO_SENDERNAME="Pana MIA"

# [VAR] [CF-RUNTIME] Brevo environment — "DEV" suppresses real sends (default: DEV)
# BREVO_ENV="DEV"

# =============================================================================
# OBJECT STORAGE (Cloudflare R2)
# https://dash.cloudflare.com/?to=/:account/r2
# =============================================================================

# [SECRET] [CF-RUNTIME] Cloudflare account ID (used for R2 S3-compatible endpoint)
R2_ACCOUNT_ID="your_cloudflare_account_id"

# [SECRET] [CF-RUNTIME] R2 API token key ID (create under R2 → Manage R2 API Tokens)
# https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ACCESS_KEY_ID="your_r2_access_key_id"

# [SECRET] [CF-RUNTIME] R2 API token secret
# https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"

# [VAR] [CF-RUNTIME] R2 bucket name (e.g. panamia-media)
R2_BUCKET_NAME="your_r2_bucket_name"

# [VAR] [CF-RUNTIME] Public base URL for the R2 bucket (r2.dev subdomain or custom domain)
# https://developers.cloudflare.com/r2/buckets/public-buckets/
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# =============================================================================
# STRIPE (Payments)
# https://dashboard.stripe.com/apikeys
# =============================================================================

# [VAR] [CF-BUILD] Stripe publishable key (public, baked into bundle at build time)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# [SECRET] [CF-RUNTIME] Stripe secret key
# STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"

# =============================================================================
# CLOUDFLARE STREAM (Events livestreaming setup)
# https://dash.cloudflare.com -> Stream -> Live Inputs
# =============================================================================

# [SECRET] [CF-RUNTIME] Cloudflare account ID
# CF_ACCOUNT_ID="your_cloudflare_account_id"

# [SECRET] [CF-RUNTIME] Cloudflare Stream API token (needs Live Inputs write permission)
# CF_STREAM_API_TOKEN="your_stream_api_token"

# [SECRET] [CF-RUNTIME] Secret used to verify Cloudflare Stream webhook requests
# Configure in CF dashboard → Stream → Webhooks → Signing Secret
# CF_STREAM_WEBHOOK_SECRET="your_stream_webhook_secret"

# [VAR] [CF-RUNTIME] Customer subdomain code for Stream embed URLs
# Found in CF dashboard → Stream → Overview — the customer-XXXX part of the embed URL
# CF_STREAM_CUSTOMER_CODE="your_customer_code"

# =============================================================================
# GOHIGHLEVEL (CRM)
# https://app.gohighlevel.com -> Settings -> Integrations -> Private Integrations
# =============================================================================

# [SECRET] [CF-RUNTIME] GHL private integration API key
# Create in GHL → Settings → Integrations → Private Integrations
# GHL_API_KEY="your_ghl_api_key"

# [SECRET] [CF-RUNTIME] GHL sub-account/location ID
# Shown in the GHL dashboard URL and in Settings.
# Not sensitive, but stored as a CF Workers secret (via `wrangler secret put`) for
# symmetry with GHL_API_KEY. Alternatively declare in wrangler.jsonc "vars".
# GHL_LOCATION_ID="your_ghl_location_id"

# [VAR] [CF-RUNTIME] GHL workflow UUID for the "Trigger test workflow" button in Advanced Settings
# Copy from the workflow URL in GHL → Automation → Workflows. Leave unset in production.
# GHL_WORKFLOW_TEST_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# =============================================================================
# DMCA AGENT (Legal)
# https://dmca.copyright.gov — Register/renew designated agent ($6, every 3 years)
# =============================================================================
#
# These values are rendered into legal/dmca/policy.html and other legal pages.
# Use a registered agent service address — not a personal address.

# [VAR] [CF-BUILD] DMCA agent full name
# DMCA_AGENT_NAME="Your Registered Agent Name"

# [VAR] [CF-BUILD] DMCA agent email for takedown notices
# DMCA_AGENT_EMAIL="dmca@panamia.club"

# [VAR] [CF-BUILD] DMCA agent physical address (registered agent service)
# DMCA_AGENT_ADDRESS="123 Agent St, Suite 100, City, ST 00000"

# [VAR] [CF-BUILD] DMCA agent phone number
# DMCA_AGENT_PHONE="+1-000-000-0000"

# [VAR] [CF-BUILD] Date of DMCA agent registration with Copyright Office (YYYY-MM-DD)
# DMCA_REGISTRATION_DATE="2026-01-01"

# [VAR] [CF-BUILD] Next renewal date (3 years from registration) (YYYY-MM-DD)
# DMCA_RENEWAL_DATE="2029-01-01"

# =============================================================================
# DEVELOPMENT / TESTING
# =============================================================================

# [LOCAL] Development email redirect (safety net)
# When set, ALL outbound emails are sent here instead of real recipients.
# Prevents accidentally emailing real users during development.
# DEV_RECEIVER_EMAIL="your_dev_email@example.com"

# =============================================================================
# HARD-CODED DOMAIN REFERENCES
# =============================================================================
#
# The string "panamia.club" appears in three categories in the source code.
# If this project is ever forked or the domain changes, update accordingly.
#
# 1. PRODUCTION DETECTION — intentional comparisons against "panamia.club"
#    to distinguish the production deployment from preview/workers.dev builds:
#      app/layout.tsx                          host.includes('panamia.club')
#      app/api/auth/verify-recaptcha/route.ts  host.includes('panamia.club')
#      components/SignupModal.tsx              NEXT_PUBLIC_HOST_URL.includes(...)
#
# 2. SITE_URL FALLBACKS — already read NEXT_PUBLIC_HOST_URL at runtime;
#    "https://panamia.club" is only a safe default if the env var is unset:
#      app/sitemap.ts
#      app/robots.ts
#      app/feed.xml/route.ts
#      app/feed.json/route.ts
#      app/feed/author/[screenname]/route.ts
#      app/feed/tag/[tag]/route.ts
#      app/feed/type/[type]/route.ts
#      lib/federation/index.ts  (extracts domain from NEXT_PUBLIC_HOST_URL)
#      app/api/create-checkout-session/route.ts  (Stripe origin fallback)
#
# 3. CONTENT LITERALS — correct to hard-code; not env-var controlled:
#      auth.ts                          email templates (footer, contact links)
#      app/doc/terms-and-conditions/    legal document text
#      app/form/become-a-pana/          error message contact email
#      app/api/createExpressProfile/    error message contact email
#      app/donation/confirmation/       contact email
#      app/links/page.tsx               mailto link
#      components/CallToActionBar.tsx   "Visit Panamia Club" link (prod URL from preview)
#      components/MainFooter.tsx        Instagram / GitHub social links
#      app/.well-known/nodeinfo/2.0/   software.name "panamia-club" in NodeInfo response
